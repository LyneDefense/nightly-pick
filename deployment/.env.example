# Nightly Pick 部署环境变量模板
# 复制为 deployment/.env 后修改

# ============ 域名 ============
DOMAIN=api.your-domain.com

# ============ 数据库 ============
POSTGRES_DB=nightly_pick
POSTGRES_USER=nightly_pick
POSTGRES_PASSWORD=change_this_database_password

# ============ 后端 ============
BUSINESS_DAY_RESET_HOUR=6
AUDIO_PUBLIC_BASE_URL=https://example.com/nightly

# ============ Agent ============
APP_ENV=production
TEXT_PROVIDER=mock
SPEECH_PROVIDER=mock

# 如果切换到 MiniMax，再配置下面这些：
# MINIMAX_API_KEY=your_minimax_api_key
# TEXT_MODEL=MiniMax-M2.5
# MINIMAX_TTS_MODEL=speech-2.8-turbo
# MINIMAX_TTS_VOICE_ID="Chinese (Mandarin)_Warm_Bestie"
# MINIMAX_ASR_ENDPOINT=https://your-asr-endpoint
