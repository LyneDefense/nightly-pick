<configuration>
    <springProperty scope="context" name="TIMING_LOG_PATH" source="server.timing-log-path" defaultValue="/app/logs/timing.log"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} [requestId=%X{requestId} sessionId=%X{sessionId} traceId=%X{traceId}] - %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="TIMING_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${TIMING_LOG_PATH}</file>
        <encoder>
            <pattern>%msg%n</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${TIMING_LOG_PATH}.%d{yyyy-MM-dd}.gz</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
    </appender>

    <logger name="com.nightlypick.server.timing" level="INFO" additivity="false">
        <appender-ref ref="TIMING_FILE"/>
    </logger>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
