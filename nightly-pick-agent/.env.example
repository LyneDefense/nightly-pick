APP_ENV=development
TEXT_PROVIDER=mock
SPEECH_PROVIDER=mock

# Text model settings
TEXT_MODEL=MiniMax-M2.5
MINIMAX_API_KEY=
MINIMAX_TEXT_BASE_URL=https://api.minimax.io/v1

# Speech settings
MINIMAX_SPEECH_BASE_URL=https://api.minimax.io/v1
MINIMAX_TTS_MODEL=speech-2.8-turbo
MINIMAX_TTS_VOICE_ID=Chinese (Mandarin)_Warm_Bestie

# Optional custom ASR endpoint if you have one configured internally
MINIMAX_ASR_ENDPOINT=
